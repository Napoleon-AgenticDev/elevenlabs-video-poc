# ElevenLabs Video Generator - Environment Variables
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# ElevenLabs API Key (get from https://elevenlabs.io/app/api)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Voice ID (get from https://elevenlabs.io/app/voices)
ELEVENLABS_VOICE_ID=sp8CrAP79SOncD3rShle

# Gemini API Key (for image generation - free tier available)
GEMINI_API_KEY=your_gemini_key_here

# =============================================================================
# OPTIONAL - Video Generation (when ElevenLabs API enables)
# =============================================================================

# Enable video generation (Veo/Kling)
USE_VIDEO_GEN=false

# Video model: veo, kling, kling-3-0-pro
VIDEO_MODEL=kling

# =============================================================================
# OPTIONAL - Content Settings
# =============================================================================

# Content rating: G, PG, PG13, R (affects robot appearance)
# CONTENT_RATING=PG13

# Music genre: ambient, cinematic, electronic, acoustic, minimalist
# MUSIC_GENRE=ambient

# Enable CC text on images: true or false
# ENABLE_CC=false